{
  "name": "pinin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PinIn — an HTML5/WebGL neon vertical pinball runner inspired by Mediocre AB's PinOut.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sim": "esbuild scripts/sim.ts --bundle --platform=node --format=esm --alias:@=./src --outfile=.sim/sim.mjs && node .sim/sim.mjs"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/three": "^0.169.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
